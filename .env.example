# Copy this file to .env (docker compose reads .env automatically) and
# adjust values as needed. All variables below have working defaults baked
# into docker-compose.yml, so an empty/absent .env is fine too.

# Person identity shown on dim_people / session_meta. Inside the watcher
# container getpass.getuser() returns 'root', which would otherwise mask
# who actually ran the Claude Code session on the host.
AURA_DEFAULT_PERSON_ID=local
AURA_DEFAULT_PERSON_NAME=Local User

# Host-side path to your Claude Code transcripts, mounted read-only into
# the watcher container at /logs/claude.
CLAUDE_LOGS_DIR=~/.claude/projects

# T8: content-hash mode (default OFF — leave unset/empty). Set to "1" or
# "true" to replace conversational text (message.content) with sha256:<hex>
# markers at ingest time, so user_prompt / assistant_response /
# prompt_text_200 / summary_200 become cryptographically non-recoverable.
# Applies to NEW ingests only (no retroactive rewrite of existing raw_events
# rows) and DISABLES the session replay / conversation view for anything
# ingested while it's on. See README "Privacy: column masking before
# anything leaves the machine".
AURA_HASH_CONTENT=
